{
  "appId": "com.daijia.chuxing",
  "appName": "代驾出行",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.amap.com",
      "*.qq.com",
      "uri.amap.com",
      "webapi.amap.com",
      "restapi.amap.com"
    ]
  },
  "android": {
    "allowMixedContent": true
    // TODO: amap-navi 插件暂时禁用（高德SDK集成存在兼容性问题）
    // "includePlugins": ["@capacitor/amap-navi"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#2C3E50",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
    // TODO: AmapNavi配置暂时禁用
    // "AmapNavi": { "apiKey": "700c467755db139a0780ef3c86276a83" }
  }
}
